# KRYVLAYER Environment Variables — copy to .env.local

# Neon PostgreSQL (from neon.tech dashboard)
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Nehira AI integration
NEHIRA_API_KEY=vk_live_...
